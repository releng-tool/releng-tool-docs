msgid "`mrproper`"
msgstr ""

#: ../../content/guides/arguments.md:162
msgid "Perform a pristine clean of the releng-tool project."
msgstr ""

#: ../../content/guides/arguments.md:168
msgid ""
"This request removes the `output/` directory found in the root directory "
