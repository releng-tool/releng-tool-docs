msgid "Configuration stage"
msgstr ""

#: ../../content/guides/packages/pkg-type-cargo.md:50
msgid "Cargo package do not have a configuration stage."
msgstr ""

#: ../../content/guides/packages/pkg-type-cargo.md:58
msgid "Build stage"
msgstr ""

#: ../../content/guides/packages/pkg-type-cargo.md:61
msgid "The build stage invokes `cargo build` with the arguments:"
msgstr ""

